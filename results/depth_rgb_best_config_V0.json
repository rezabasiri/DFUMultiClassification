  "stage1_epochs": 100,
  "early_stop_patience": 15,
  "reduce_lr_patience": 7,
  "batch_size": 64,
  "lr_schedule": "plateau",
  "warmup_epochs": 0,
  "loss_type": "focal",
  "focal_gamma": 3.0,
  "alpha_sum": 3.0,
  "label_smoothing": 0.0,
  "use_augmentation": false,
  "use_mixup": false,
  "mixup_alpha": 0.0,
  "image_size": 256,
  "finetune_lr": 1e-05,
  "finetune_epochs": 30,
  "fold": 0
}